{
  "name": "universal-agent-enforcer",
  "version": "1.0.0",
  "description": "Strict framework for AI Agents with Cloudflare bypass, auto-backup, DevTools self-healing, and strict quality testing gates.",
  "main": "scripts/orchestrator.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/server.ts",
    "build": "npm run agent:fact-check && tsx scripts/build.ts && npm run agent:analyze-build",
    "test": "vitest run && playwright test",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality-gate": "npm run lint && npm run format:check && npm run agent:fact-check",
    "agent:backup": "tsx scripts/backup-guard.ts backup",
    "agent:restore": "tsx scripts/backup-guard.ts restore",
    "agent:check-network": "tsx scripts/network-monitor.ts",
    "agent:fact-check": "tsx scripts/fact-checker.ts",
    "agent:analyze-build": "tsx scripts/build-analyzer.ts",
    "agent:browser": "tsx scripts/stealth-browser.ts",
    "agent:devtools": "tsx scripts/devtools-monitor.ts",
    "agent:test-run": "tsx scripts/test-runner.ts",
    "agent:visual": "tsx scripts/visual-regression.ts",
    "agent:orchestrate": "tsx scripts/orchestrator.ts",
    "agent:audit": "tsx scripts/quality-auditor.ts"
  },
  "keywords": [
    "ai-agent",
    "enforcer",
    "devtools",
    "cloudflare-bypass",
    "puppeteer-stealth",
    "guardrails",
    "orchestrator"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.44.1",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.3.0",
    "globals": "^17.6.0",
    "playwright": "^1.44.1",
    "prettier": "^3.3.0",
    "puppeteer": "^22.10.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tsx": "^4.15.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^1.6.0"
  }
}
