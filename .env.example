# =============================================================================
# Universal Agent Enforcer - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your setup.
#   cp .env.example .env
#
# IMPORTANT: Never commit real API keys or tokens to version control.
#            The Fact Checker script will detect and block hardcoded secrets.
# =============================================================================

# --- Orchestrator Configuration ---
# Maximum number of orchestration loop iterations (default: 5)
MAX_ORCHESTRATE_LOOPS=5

# LLM provider for the orchestrator (default: local)
# This variable is logged for reference and does not affect pipeline behavior.
# Options: local | openai | anthropic | google
AGENT_LLM_PROVIDER=local

# --- Browser / Stealth Configuration ---
# Remote debugging port for CloakBrowser or anti-detect browser (default: 9222)
REMOTE_DEBUG_PORT=9222

# --- Build Analyzer Configuration ---
# Minimum bundle size threshold in KB to flag as suspiciously small (default: 10)
MIN_BUNDLE_SIZE_KB=10

# --- Dev Server Configuration ---
# Port for the built-in dev server (default: 3001)
DEV_SERVER_PORT=3001

# --- Network / Proxy ---
# Uncomment and set if behind a corporate proxy or VPN
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# --- API Keys (optional, for LLM integrations) ---
# Only required if AGENT_LLM_PROVIDER is set to a cloud provider.
# NEVER commit real keys to version control. Use environment variables only.

# OpenAI API key (required if AGENT_LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API key (required if AGENT_LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google AI API key (required if AGENT_LLM_PROVIDER=google)
# GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# GitHub personal access token (optional, used for repository operations)
# GITHUB_TOKEN=ghp_your-github-token-here
