# =============================================================================
# Universal Agent Enforcer - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in the values for your setup.
#   cp .env.example .env
# =============================================================================

# --- Orchestrator Configuration ---
# Maximum number of orchestration loop iterations (default: 5)
MAX_ORCHESTRATE_LOOPS=5

# LLM provider for the orchestrator (default: local)
# Options: local | openai | anthropic | google
AGENT_LLM_PROVIDER=local

# --- Browser / Stealth Configuration ---
# Remote debugging port for CloakBrowser or anti-detect browser (default: 9222)
REMOTE_DEBUG_PORT=9222

# --- Build Analyzer Configuration ---
# Minimum bundle size threshold in KB to flag as suspiciously small (default: 10)
MIN_BUNDLE_SIZE_KB=10

# --- Network / Proxy ---
# Uncomment and set if behind a corporate proxy or VPN
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080

# --- API Keys (NEVER commit real keys to version control) ---
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# GOOGLE_API_KEY=your-google-api-key-here
# GITHUB_TOKEN=ghp_your-github-token-here
